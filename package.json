{
  "name": "whatsauto-frontend",
  "version": "0.1.0",
  "description": "WhatsAuto ClojureScript frontend build tools",
  "scripts": {
    "cljs:watch": "npx shadow-cljs watch app",
    "cljs:release": "npx shadow-cljs release app",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build": "npm run cljs:release && tauri build",
    "lint": "npx clj-kondo --lint src",
    "fmt": "npx cljfmt check src",
    "fmt:fix": "npx cljfmt fix src"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "lucide-react": "^0.460.0",
    "radix-ui": "^1.4.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "shadow-cljs": "2.28.9",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "typescript": "~5.9.3"
  }
}
