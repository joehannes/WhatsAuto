{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "WhatsAuto",
  "version": "0.1.0",
  "identifier": "com.joehannes.whatsauto",
  "build": {
    "beforeDevCommand": "npm run cljs:watch",
    "beforeBuildCommand": "npm run cljs:release",
    "devUrl": "http://localhost:3449",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WhatsAuto",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/wa-sidecar"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "store": {}
  }
}
